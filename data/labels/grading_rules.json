  "grading_rules": {
    "critical_keywords": {
      "description": "机密级别关键字 - 匹配后强制提升到第4级/机密",
      "keywords": [
        "password", "passwd", "pwd", "secret", "private_key", "私钥",
        "id_card", "身份证", "bank_card", "银行卡", "credit_card",
        "ssn", "social_security", "社保号", "tax_id", "税号",
        "api_key", "apikey", "access_key", "access_secret"
      ]
    },
    "sensitive_keywords": {
      "description": "敏感级别关键字 - 匹配后提升到第3级/敏感（但不覆盖机密）",
      "keywords": [
        "salary", "wage", "工资", "bonus", "奖金", "income", "收入",
        "balance", "余额", "tax", "税",
        "medical", "医保", "health", "健康", "disease", "病",
        "crime", "犯罪", "fraud", "欺诈", "score", "评分",
        "password", "passwd", "pwd", "secret", "私钥",
        "id_card", "身份证", "bank_card", "银行卡", "credit_card",
        "ssn", "社保号"
      ]
    },
    "sample_patterns": {
      "description": "样本值模式匹配规则",
      "rules": [
        {
          "pattern": "\\d{15}|\\d{18}",
          "min_length": 15,
          "grade": "第4级/机密",
          "description": "身份证号（15或18位数字）"
        },
        {
          "pattern": "1[3-9]\\d{9}",
          "grade": "第3级/敏感",
          "description": "手机号（中国大陆手机号格式）"
        },
        {
          "pattern": ".+@.+",
          "grade": "第3级/敏感",
          "description": "邮箱地址"
        },
        {
          "patterns": ["amount", "price", "balance", "salary"],
          "keywords": ["元", "¥", "$", "€"],
          "grade": "第3级/敏感",
          "description": "金额相关字段且包含货币符号或金额关键字"
        }
      ]
    }
  },

  "grading_logic": {
    "step1": "根据 classification 获取基础分级",
    "step2": "检查字段名是否包含机密关键字 -> 第4级/机密",
    "step3": "检查字段名是否包含敏感关键字 -> 第3级/敏感",
    "step4": "检查样本值匹配身份证号模式 -> 第4级/机密",
    "step5": "检查样本值匹配手机号模式 -> 第3级/敏感",
    "step6": "检查样本值是否为邮箱 -> 第3级/敏感",
    "step7": "检查是否为敏感金额字段 -> 第3级/敏感",
    "step8": "返回最终分级"
  },

